{
  "compilerOptions": {
    "module": "es2015",
    "moduleResolution": "bundler",
    "lib": ["es6"],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noEmit": true,

    "baseUrl": ".",
    "types": [],
    "paths": {
      "handlebars": ["."]
    }
  }
}
